# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://user:password@localhost:5432/sheeshatonight_dev"

# ============================================
# SERVER
# ============================================
NODE_ENV=development
PORT=5000
HOST=localhost

# ============================================
# JWT
# ============================================
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_REFRESH_SECRET=your_refresh_token_secret_change_in_production
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# ============================================
# CORS
# ============================================
FRONTEND_URL=http://localhost:3002
ALLOWED_ORIGINS=http://localhost:3002,http://localhost:3000

# ============================================
# EMAIL (Nodemailer)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@sheeshatonight.com

# ============================================
# OTP
# ============================================
OTP_EXPIRY=10
OTP_LENGTH=6

# ============================================
# PAYMENT GATEWAY
# ============================================
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

CHECKOUT_PUBLIC_KEY=pk_xxx
CHECKOUT_SECRET_KEY=sk_xxx

# ============================================
# COMMISSION
# ============================================
VENDOR_COMMISSION_RATE=15
PLATFORM_COMMISSION_RATE=5

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=debug
LOG_FORMAT=json
