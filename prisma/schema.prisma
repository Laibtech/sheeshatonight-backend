// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  CUSTOMER
  VENDOR
  ADMIN
  ACCOUNTANT
  ORDER_PROCESSOR
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
  DELETED
}

enum VerificationType {
  EMAIL
  PHONE
  IDENTITY
  BUSINESS
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  RESUBMITTED
}

enum ProductType {
  SALE
  RENTAL
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
  ARCHIVED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  COMPLETED
  CANCELLED
  REFUNDED
  DISPUTED
}

enum OrderType {
  PURCHASE
  RENTAL
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  DISPUTED
}

enum PaymentMethod {
  CARD
  BANK_TRANSFER
  WALLET
  STRIPE
  CHECKOUT
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum SubscriptionPlan {
  FREE
  BASIC
  PREMIUM
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAUSED
}

enum NotificationType {
  ORDER
  PAYMENT
  REVIEW
  SYSTEM
  PROMOTION
}

// ============================================
// USERS & AUTHENTICATION
// ============================================

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  phone         String?  @unique
  passwordHash  String
  firstName     String?
  lastName      String?
  role          UserRole @default(CUSTOMER)
  status        UserStatus @default(ACTIVE)
  
  // Profile
  avatar        String?
  bio           String?
  region        String?
  
  // Verification
  emailVerified Boolean @default(false)
  phoneVerified Boolean @default(false)
  
  // Contact
  addresses     Address[]
  
  // Relations
  vendor        Vendor?
  customer      Customer?
  orders        Order[]
  cart          Cart?
  reviews       Review[]
  wishlist      WishlistItem[]
  notifications Notification[]
  auditLogs     AuditLog[]
  documents     Document[]
  payouts       Payout[] @relation("VendorPayouts")
  
  // Subscription
  subscriptions Subscription[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?
  
  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([status])
}

// ============================================
// CUSTOMER
// ============================================

model Customer {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Loyalty
  totalSpent    Float @default(0)
  totalOrders   Int @default(0)
  loyaltyPoints Int @default(0)
  
  // Preferences
  preferences   Json @default("{}")
  
  // Subscription
  subscriptions Subscription[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============================================
// VENDOR
// ============================================

model Vendor {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Business Info
  businessName    String
  businessType    String
  description     String?
  website         String?
  socialMedia     Json @default("{}")
  
  // Location
  operatingRegions String[]
  
  // Verification & KYC
  kycStatus       VerificationStatus @default(PENDING)
  kycDocument     String?
  kycVerifiedAt   DateTime?
  kycVerifiedBy   String?
  
  // Ratings & Performance
  rating          Float @default(5.0)
  reviewCount     Int @default(0)
  responseTime    Float @default(24) // hours
  
  // Financial
  commissionRate  Float @default(15) // percentage
  totalEarnings   Float @default(0)
  totalPayouts    Float @default(0)
  
  // Products
  products        Product[]
  
  // Orders
  orders          Order[] @relation("VendorOrders")
  
  // Subscription
  subscriptions Subscription[]
  
  // Verification
  verifications   Verification[]
  
  // Documents
  documents       Document[]
  
  // Dispute
  disputes        Dispute[] @relation("VendorDisputes")
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================
// VERIFICATION & KYC
// ============================================

model Verification {
  id              String   @id @default(uuid())
  vendorId        String
  vendor          Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  
  type            VerificationType
  status          VerificationStatus @default(PENDING)
  document        String?
  notes           String?
  
  submittedAt     DateTime @default(now())
  verifiedAt      DateTime?
  verifiedBy      String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([vendorId])
  @@index([status])
}

// ============================================
// PRODUCTS
// ============================================

model Product {
  id              String   @id @default(uuid())
  vendorId        String
  vendor          Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  
  // Basic Info
  title           String
  description     String
  sku             String   @unique
  category        String
  subcategory     String?
  
  // Type
  type            ProductType @default(SALE)
  
  // Pricing - Sale
  price           Float?
  
  // Pricing - Rental
  rentalDailyRate   Float?
  rentalWeeklyRate  Float?
  rentalMonthlyRate Float?
  rentalDeposit     Float?
  minRentalDays     Int @default(1)
  maxRentalDays     Int?
  
  // Media
  images          String[]
  thumbnail       String?
  
  // Inventory
  quantity        Int @default(0)
  
  // Availability (for rentals)
  availableFrom   DateTime?
  availableUntil  DateTime?
  
  // Status
  status          ProductStatus @default(ACTIVE)
  
  // SEO
  slug            String   @unique
  tags            String[]
  
  // Relations
  orderItems      OrderItem[]
  cartItems       CartItem[]
  reviews         Review[]
  wishlist        WishlistItem[]
  calendar        RentalCalendar[]
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([vendorId])
  @@index([category])
  @@index([status])
  @@index([slug])
}

// ============================================
// RENTAL CALENDAR & AVAILABILITY
// ============================================

model RentalCalendar {
  id              String   @id @default(uuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  date            DateTime
  isAvailable     Boolean @default(true)
  bookedBy        String?
  orderId         String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([productId, date])
  @@index([productId])
  @@index([date])
}

// ============================================
// ORDERS
// ============================================

model Order {
  id              String   @id @default(uuid())
  orderNumber     String   @unique
  customerId      String
  customer        User     @relation(fields: [customerId], references: [id])
  
  vendorId        String?
  vendor          Vendor?  @relation("VendorOrders", fields: [vendorId], references: [id])
  
  type            OrderType @default(PURCHASE)
  status          OrderStatus @default(PENDING)
  
  // Rental Specific
  rentalStartDate DateTime?
  rentalEndDate   DateTime?
  rentalDays      Int?
  
  // Pricing
  subtotal        Float @default(0)
  tax             Float @default(0)
  shippingCost    Float @default(0)
  discountAmount  Float @default(0)
  totalAmount     Float @default(0)
  
  // Commission
  commissionAmount Float @default(0)
  
  // Items
  items           OrderItem[]
  
  // Shipping
  shippingAddress String?
  trackingNumber  String?
  
  // Payment
  payment         Payment?
  
  // Notes
  notes           String?
  
  // Disputes
  disputes        Dispute[]
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([customerId])
  @@index([vendorId])
  @@index([status])
  @@index([orderNumber])
}

model OrderItem {
  id              String   @id @default(uuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  
  quantity        Int
  unitPrice       Float
  totalPrice      Float
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([orderId])
  @@index([productId])
}

// ============================================
// CART
// ============================================

model Cart {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  items           CartItem[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CartItem {
  id              String   @id @default(uuid())
  cartId          String
  cart            Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  quantity        Int
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([cartId, productId])
  @@index([cartId])
}

// ============================================
// PAYMENTS
// ============================================

model Payment {
  id              String   @id @default(uuid())
  orderId         String   @unique
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  amount          Float
  currency        String @default("AED")
  status          PaymentStatus @default(PENDING)
  method          PaymentMethod
  
  // Payment Gateway
  transactionId   String?
  gatewayResponse Json?
  
  // Retry
  retryCount      Int @default(0)
  lastRetryAt     DateTime?
  
  // Webhook
  webhookId       String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([orderId])
  @@index([status])
}

// ============================================
// PAYOUTS
// ============================================

model Payout {
  id              String   @id @default(uuid())
  vendorId        String
  vendor          User     @relation("VendorPayouts", fields: [vendorId], references: [id])
  
  amount          Float
  currency        String @default("AED")
  status          PayoutStatus @default(PENDING)
  
  bankAccount     String?
  bankCode        String?
  
  transactionId   String?
  processedAt     DateTime?
  
  failureReason   String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([vendorId])
  @@index([status])
}

// ============================================
// SUBSCRIPTION
// ============================================

model Subscription {
  id              String   @id @default(uuid())
  
  // User or Vendor
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  vendorId        String?
  vendor          Vendor?  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  
  plan            SubscriptionPlan @default(FREE)
  status          SubscriptionStatus @default(ACTIVE)
  
  amount          Float @default(0)
  billingCycle    String @default("monthly")
  
  startDate       DateTime @default(now())
  endDate         DateTime?
  renewalDate     DateTime?
  
  cancelledAt     DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([userId])
  @@index([customerId])
  @@index([vendorId])
}

// ============================================
// REVIEWS & RATINGS
// ============================================

model Review {
  id              String   @id @default(uuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  rating          Int @default(5)
  title           String?
  content         String?
  images          String[]
  
  helpful         Int @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([productId])
  @@index([userId])
}

// ============================================
// WISHLIST
// ============================================

model WishlistItem {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())
  
  @@unique([userId, productId])
  @@index([userId])
}

// ============================================
// ADDRESSES
// ============================================

model Address {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  label           String?
  street          String
  city            String
  state           String?
  postalCode      String?
  country         String @default("AE")
  
  isDefault       Boolean @default(false)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([userId])
}

// ============================================
// DOCUMENTS
// ============================================

model Document {
  id              String   @id @default(uuid())
  
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  vendorId        String?
  vendor          Vendor?  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  
  type            String
  fileName        String
  fileUrl         String
  fileSize        Int
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================
// DISPUTES
// ============================================

model Dispute {
  id              String   @id @default(uuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  vendorId        String?
  vendor          Vendor?  @relation("VendorDisputes", fields: [vendorId], references: [id])
  
  reason          String
  description     String?
  status          String @default("OPEN")
  
  resolution      String?
  resolvedAt      DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([orderId])
  @@index([vendorId])
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type            NotificationType
  title           String
  message         String
  data            Json @default("{}")
  
  read            Boolean @default(false)
  readAt          DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([userId])
  @@index([read])
}

// ============================================
// AUDIT LOGS
// ============================================

model AuditLog {
  id              String   @id @default(uuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  action          String
  entity          String
  entityId        String?
  
  changes         Json @default("{}")
  ipAddress       String?
  userAgent       String?
  
  createdAt       DateTime @default(now())
  
  @@index([userId])
  @@index([action])
  @@index([entity])
}
